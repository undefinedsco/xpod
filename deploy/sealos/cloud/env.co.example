# Xpod Cloud 部署 - Sealos App Launchpad 配置指南
#
# ============================================================
# Sealos App Launchpad 填写说明
# 也可直接将本文件完整内容保存到 GitHub Environment Secret `APP_ENV_FILE`
# ============================================================
#
# 【基本信息】
#   应用名称: xpod
#   镜像:     ghcr.io/undefinedsco/xpod:0.2.1
#   CPU:      0.5 核（最低）
#   内存:     1 Gi（建议起步）
#
# 【启动命令】（覆盖 Dockerfile CMD）
#   Command:  node
#   Args:     dist/main.js -m cloud -p 3000 --host 0.0.0.0
#
# 【网络】
#   容器暴露端口: 3000（Gateway 统一入口，CSS 和 API 内部端口自动分配）
#   外网访问:     开启
#
# 【健康检查】
#   存活探针:  HTTP GET /service/status 端口 3000
#   就绪探针:  HTTP GET /service/status 端口 3000
#
# 【环境变量】把下面的 key=value 逐条填入
# ============================================================

# ---- 运行模式 ----
NODE_ENV=production
XPOD_EDITION=cloud

# ---- 域名 ----
# xpod 主入口走 id 子域名；裸域建议留给 homepage
CSS_BASE_URL=https://id.undefineds.co
# 可选：显式指定 OIDC issuer；不填时默认与 CSS_BASE_URL 一致
# CSS_OIDC_ISSUER=https://id.undefineds.co
CSS_ALLOWED_HOSTS=id.undefineds.co,pods.undefineds.co,api.undefineds.co

# local SP / edge 节点子域名根域名（例如 <node-id>.undefineds.site）
CSS_BASE_STORAGE_DOMAIN=undefineds.site

# ---- 功能开关 ----
XPOD_EDGE_NODES_ENABLED=true
CSS_LOGGING_LEVEL=info

# ---- PostgreSQL (Supabase，建议 direct connection) ----
CSS_SPARQL_ENDPOINT=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
CSS_IDENTITY_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# 如启用向量检索，确保 Supabase 已开启 pgvector 扩展
# CREATE EXTENSION IF NOT EXISTS vector;

# ---- Redis (Upstash, TLS) ----
CSS_REDIS_CLIENT=rediss://default:your-password@your-host.upstash.io:6379

# ---- 对象存储 (Cloudflare R2) ----
CSS_MINIO_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CSS_MINIO_ACCESS_KEY=your-r2-access-key
CSS_MINIO_SECRET_KEY=your-r2-secret-key
CSS_MINIO_BUCKET_NAME=xpod

# ---- Cloudflare DNS（API Server 通过 process.env 读取）----
CLOUDFLARE_API_TOKEN=your-dns-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id

# ---- 外部权益服务（可选，xpod 主动拉取）----
# 账户配额优先级：本地自定义配额 > 远端 entitlement > XPOD_DEFAULT_* 默认值
# XPOD_ENTITLEMENTS_BASE_URL=https://billing.undefineds.co
# XPOD_ENTITLEMENTS_SERVICE_TOKEN=svc-your-internal-token
# XPOD_ENTITLEMENTS_CACHE_TTL_MS=60000
# XPOD_ENTITLEMENTS_TIMEOUT_MS=5000

# ---- 可选: SMTP 邮件（不填则禁用） ----
# CSS_EMAIL_CONFIG_HOST=smtp.example.com
# CSS_EMAIL_CONFIG_PORT=465
# CSS_EMAIL_CONFIG_AUTH_USER=no-reply@example.com
# CSS_EMAIL_CONFIG_AUTH_PASS=your-smtp-password
