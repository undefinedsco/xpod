# Xpod Cloud 部署 - 新加坡环境变量示例
#
# 使用方式：
#   1. 复制此文件并填入实际值
#   2. 在 Sealos App Launchpad 创建应用时，将这些环境变量填入
#   3. 或通过 kubectl 创建 Secret/ConfigMap
#
# 镜像: ghcr.io/undefinedsco/xpod:latest
# 启动命令: node dist/main.js -m cloud -p 3000 --host 0.0.0.0
# 健康检查: GET /service/status :3000

# ============ 基础配置 ============
NODE_ENV=production
XPOD_EDITION=cloud
CSS_PORT=6300
API_PORT=6301
CSS_LOGGING_LEVEL=info

# ============ 域名配置 ============
# 主域名（HTTPS，用于 OIDC issuer 和 WebID）
CSS_BASE_URL=https://undefineds.co
# 额外允许的 host（逗号分隔，*.baseDomain 的子域名自动允许）
CSS_ALLOWED_HOSTS=id.undefineds.co,pods.undefineds.co
# 用于分配给 local 节点的子域名根域
XPOD_DDNS_DOMAIN=undefineds.co

# ============ 功能开关 ============
XPOD_EDGE_NODES_ENABLED=true
XPOD_SUBDOMAIN_ENABLED=true

# ============ PostgreSQL (Neon Serverless) ============
# 格式: postgresql://user:pass@host/db?sslmode=require
CSS_SPARQL_ENDPOINT=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
CSS_IDENTITY_DB_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ============ Redis (Upstash Serverless) ============
# 格式: rediss://default:password@host:6379 (注意 rediss:// 双 s 表示 TLS)
CSS_REDIS_CLIENT=rediss://default:your-password@your-host.upstash.io:6379

# ============ 对象存储 (Cloudflare R2) ============
# Endpoint 格式: https://<account-id>.r2.cloudflarestorage.com
CSS_MINIO_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CSS_MINIO_ACCESS_KEY=your-r2-access-key
CSS_MINIO_SECRET_KEY=your-r2-secret-key
CSS_MINIO_BUCKET_NAME=xpod

# ============ Cloudflare DNS (子域名动态解析) ============
CLOUDFLARE_API_TOKEN=your-dns-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id

# ============ 可选: SMTP 邮件 ============
# 不配置则禁用邮件功能（密码重置等）
# CSS_EMAIL_CONFIG_HOST=smtp.example.com
# CSS_EMAIL_CONFIG_PORT=465
# CSS_EMAIL_CONFIG_AUTH_USER=no-reply@example.com
# CSS_EMAIL_CONFIG_AUTH_PASS=your-smtp-password
