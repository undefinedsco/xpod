<script>
// 全局持久化 provisionCode：用户从 /.account/?provisionCode=xxx 进入后，
// 无论经过注册、登录多少步，最终到 create-pod 页面时 provisionCode 都在。
(function() {
  try {
    var pc = new URLSearchParams(location.search).get('provisionCode');
    if (pc) sessionStorage.setItem('provisionCode', pc);
  } catch(e) {}
})();
</script>
<%- htmlBody %>
